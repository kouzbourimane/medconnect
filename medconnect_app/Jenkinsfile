pipeline {
    agent any

    environment {
        DOCKER_HUB_CREDENTIALS_ID = 'dockerhub-credentials'
        DOCKER_IMAGE_NAME = 'imanekouzbour/medconnect-backend'
        IMAGE_TAG = "${env.BUILD_NUMBER}"
        FIREBASE_TOKEN = credentials('firebase-token')
        FIREBASE_APP_ID = '1:621469238732:android:ead2ba093a5c9907f80969'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Code clone avec succes"
            }
        }

        stage('Build') {
            parallel {
                stage('Backend - Install') {
                    steps {
                        dir('medconnect_app/medconnect-backend') {
                           sh 'pip3 install -r requirements.txt --break-system-packages'
                            echo "✅ Backend dependencies installes"
                        }
                    }
                }
                stage('Frontend - Install') {
                    steps {
                        dir('medconnect_app/medconnect-frontend') {
                            sh 'flutter pub get'
                            echo "✅ Frontend dependencies installes"
                        }
                    }
                }
            }
        }

       stage('Backend - Tests') {
            steps {
                 dir('medconnect_app/medconnect-backend') {
                 sh 'CI=true python3 manage.py test'
                 echo "✅ Tests backend passes"
        }
    }
}
                    }
                }
                stage('Frontend - Analyze') {
                    steps {
                        dir('medconnect_app/medconnect-frontend') {
                            sh 'flutter analyze --no-fatal-infos --no-fatal-warnings || true'
                            echo "✅ Analyse frontend terminee"
                        }
                    }
                }
            }
        }

        stage('Docker - Build') {
            steps {
                dir('medconnect_app/medconnect-backend') {
                    echo "Construction de l image Docker..."
                    script {
                        env.DOCKER_IMAGE_FULL = "${DOCKER_IMAGE_NAME}:${IMAGE_TAG}"
                        docker.build(env.DOCKER_IMAGE_FULL)
                    }
                }
            }
        }

        stage('Docker - Push') {
            steps {
                echo "Envoi de l image sur DockerHub..."
                script {
                    def img = docker.image(env.DOCKER_IMAGE_FULL)
                    docker.withRegistry('https://index.docker.io/v1/', "${DOCKER_HUB_CREDENTIALS_ID}") {
                        img.push()
                        img.push('latest')
                    }
                }
            }
        }

        stage('Deploy - Kubernetes') {
            steps {
                echo "Deploiement sur Kubernetes..."
                sh 'kubectl apply -f medconnect_app/k8s/backend-deployment.yaml'
                sh 'kubectl apply -f medconnect_app/k8s/backend-service.yaml'
                sh 'kubectl rollout status deployment/medconnect-backend --timeout=120s'
                echo "✅ Backend deploye sur Kubernetes"
            }
        }

        stage('Frontend - Build APK') {
            steps {
                dir('medconnect_app/medconnect-frontend') {
                    echo "Construction de l APK Flutter..."
                    sh 'export ANDROID_HOME=/opt/android-sdk && flutter build apk --release'
                    echo "✅ APK construit avec succes"
                }
            }
        }

        stage('Frontend - Deploy Firebase') {
            steps {
                echo "Deploiement sur Firebase App Distribution..."
                sh """
                    npx firebase appdistribution:distribute \
                    medconnect_app/medconnect-frontend/build/app/outputs/flutter-apk/app-release.apk \
                    --app ${FIREBASE_APP_ID} \
                    --token ${FIREBASE_TOKEN} \
                    --release-notes "Build ${IMAGE_TAG} - Deploiement automatique"
                """
                echo "✅ APK deploye sur Firebase"
            }
        }
    }

    post {
        success {
            echo "Pipeline termine avec succes !"
        }
        failure {
            echo "Pipeline echoue - verifier les logs"
        }
    }
}